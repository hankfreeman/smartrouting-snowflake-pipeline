# TransUnion API (required for /route; set on Snowflake service or in .env — never commit .env)
TU_USERNAME=your_tu_username
TU_PASSWORD=your_tu_password
TU_SERVICE_ID=your_transunion_service_id
TU_CONFIG_ID=your_transunion_configuration_id
# TU_API_URL=https://webgwy.neustar.biz/api/identity-v4

# Snowflake (for deploy_5tower_snowflake.py)
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_ROLE=your_role

# Optional: override defaults
# SNOWFLAKE_DATABASE=YOUR_DATABASE
# SNOWFLAKE_SCHEMA=YOUR_SCHEMA
# COMPUTE_POOL=CPU_S
# EXTERNAL_ACCESS_INTEGRATION=transunion_access_integration
# IMAGE_REPO=model_repo
# IMAGE_NAME_5TOWER=smart-routing-5tower
# SMART_ROUTING_5TOWER_SERVICE_NAME=SMART_ROUTING_5TOWER_SERVICE

# For testing deployed endpoint (after deploy)
# BASE_URL=https://<your-endpoint>.snowflakecomputing.app
